# Optional for local development. Render binds this automatically from auralis-db.
DATABASE_URL=

# Optional. Enter this during Blueprint creation or add it in the Render dashboard.
YOUTUBE_API_KEY=

NEXT_PUBLIC_APP_NAME=Auralis
NEXT_PUBLIC_APP_MODE=development

# Reserved application secrets. Render generates production values automatically.
APP_SECRET=
NEXTAUTH_SECRET=

# Change this to the deployed URL if the Render web service is renamed.
NEXTAUTH_URL=http://localhost:3000
