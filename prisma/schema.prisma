generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserSetting {
  id        String   @id @default(cuid())
  userKey   String   @unique @default("local-user")
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artist {
  id        String   @id @default(cuid())
  name      String
  bio       String?
  genres    String[]
  artwork   Json?
  albums    Album[]
  tracks    Track[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Album {
  id          String   @id @default(cuid())
  title       String
  description String?
  year        Int?
  genres      String[]
  artwork     Json?
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks      Track[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Track {
  id             String   @id @default(cuid())
  title          String
  duration       Int
  source         String
  genres         String[]
  year           Int?
  artwork        Json?
  youtubeVideoId String?
  localBlobId    String?
  artistId       String
  artist         Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  albumId        String
  album          Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Playlist {
  id          String          @id @default(cuid())
  title       String
  description String?
  artwork     Json?
  tags        String[]
  ownerKey    String          @default("local-user")
  tracks      PlaylistTrack[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PlaylistTrack {
  playlistId String
  trackId    String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([playlistId, trackId])
  @@index([playlistId, position])
  @@index([trackId])
}

model Favorite {
  id        String   @id @default(cuid())
  userKey   String   @default("local-user")
  trackId   String
  createdAt DateTime @default(now())

  @@unique([userKey, trackId])
  @@index([trackId])
}

model PlayHistory {
  id       String   @id @default(cuid())
  userKey  String   @default("local-user")
  trackId  String
  playedAt DateTime @default(now())

  @@index([userKey, playedAt])
  @@index([trackId])
}

model Lyric {
  id        String   @id @default(cuid())
  trackId   String   @unique
  plainText String?
  lrc       String?
  offset    Int      @default(0)
  updatedAt DateTime @updatedAt
}

model LocalFileMetadata {
  id        String   @id @default(cuid())
  trackId   String   @unique
  fileName  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}
